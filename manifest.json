<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, user-scalable=no" />
<title>Crate</title>
<meta name="theme-color" content="#0B0A0F" />
<link rel="manifest" href="manifest.json" />
<link rel="apple-touch-icon" href="icons/icon-192.png" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="Crate" />
<link rel="stylesheet" href="styles.css" />
</head>
<body>

  <!-- ===== Setup / sign-in screen ===== -->
  <section id="setup" class="setup">
    <div class="setup-card">
      <div class="brand">
        <span class="brand-mark"></span>
        <h1>Crate</h1>
      </div>
      <p class="setup-copy">Your own library, streamed from your own Drive.</p>
      <button id="signin-btn" class="btn-primary">Connect Google Drive</button>
      <p id="setup-note" class="setup-note"></p>
    </div>
  </section>

  <!-- ===== Main app ===== -->
  <div id="app" class="app hidden">

    <header class="topbar">
      <div class="brand">
        <span class="brand-mark"></span>
        <h1>Crate</h1>
      </div>
      <button id="folder-btn" class="icon-btn" title="Change folder">⚙︎</button>
    </header>

    <div class="search-row">
      <input id="search" type="search" placeholder="Search songs, artists…" />
      <button id="refresh-btn" class="icon-btn" title="Refresh from Drive">⟳</button>
    </div>

    <main class="main">
      <!-- Library -->
      <section id="view-library" class="view">
        <div class="view-head">
          <h2>Your Library</h2>
          <span id="track-count" class="view-count"></span>
        </div>
        <ol id="track-list" class="track-list"></ol>
        <p id="empty-state" class="empty-state hidden">Nothing here yet — tap ⟳ to pull songs from your Drive folder.</p>
      </section>

      <!-- Playlists -->
      <section id="view-playlists" class="view hidden">
        <div class="view-head">
          <h2>Playlists</h2>
          <button id="new-playlist-btn" class="btn-pill">+ New</button>
        </div>
        <div id="playlist-grid" class="playlist-grid"></div>
        <div id="playlist-detail" class="playlist-detail hidden">
          <button id="playlist-back" class="link-btn">← All playlists</button>
          <h3 id="playlist-detail-title"></h3>
          <ol id="playlist-detail-tracks" class="track-list"></ol>
        </div>
      </section>

      <!-- Downloaded -->
      <section id="view-downloads" class="view hidden">
        <div class="view-head">
          <h2>Downloaded</h2>
          <span id="download-count" class="view-count"></span>
        </div>
        <div class="storage-line"><span id="storage-used">0 MB</span> stored on this phone</div>
        <ol id="download-list" class="track-list"></ol>
        <p id="download-empty" class="empty-state hidden">Nothing downloaded yet — tap the ⬇ on any song to keep it offline.</p>
      </section>
    </main>

    <!-- Mini player -->
    <button id="mini-player" class="mini-player hidden">
      <img id="mini-art" class="mini-art" alt="" />
      <div class="mini-meta">
        <div id="mini-title" class="mini-title">—</div>
        <div id="mini-artist" class="mini-artist">—</div>
      </div>
      <span id="mini-playpause" class="mini-playpause">▶</span>
    </button>

    <!-- Bottom tab bar -->
    <nav class="tabbar">
      <button class="tab-item is-active" data-view="library">
        <span class="tab-icon">◆</span><span>Library</span>
      </button>
      <button class="tab-item" data-view="playlists">
        <span class="tab-icon">▤</span><span>Playlists</span>
      </button>
      <button class="tab-item" data-view="downloads">
        <span class="tab-icon">⬇</span><span>Downloaded</span>
      </button>
    </nav>
  </div>

  <!-- ===== Full-screen Now Playing ===== -->
  <section id="now-playing" class="now-playing hidden">
    <div class="np-backdrop" id="np-backdrop"></div>
    <div class="np-content">
      <header class="np-head">
        <button id="np-collapse" class="icon-btn">⌄</button>
        <span class="np-head-label">Now Playing</span>
        <button id="np-signout" class="icon-btn" title="Sign out">⏻</button>
      </header>

      <div class="np-art-wrap">
        <img id="np-art" class="np-art" alt="" />
      </div>

      <div class="np-info">
        <div>
          <div id="np-title" class="np-title">—</div>
          <div id="np-artist" class="np-artist">—</div>
        </div>
        <button id="np-download" class="icon-btn" title="Download for offline">⬇</button>
      </div>

      <div class="np-progress">
        <input id="np-seek" type="range" min="0" max="1000" value="0" />
        <div class="np-times">
          <span id="np-time-cur">0:00</span>
          <span id="np-time-dur">0:00</span>
        </div>
      </div>

      <div class="np-controls">
        <button id="btn-shuffle" class="np-ctrl" title="Shuffle">⇄</button>
        <button id="btn-prev" class="np-ctrl" title="Previous">⏮</button>
        <button id="btn-play" class="np-ctrl np-ctrl-main" title="Play/Pause">▶</button>
        <button id="btn-next" class="np-ctrl" title="Next">⏭</button>
        <button id="btn-repeat" class="np-ctrl" title="Repeat">↻</button>
      </div>
    </div>
  </section>

  <div id="toast" class="toast hidden"></div>

  <audio id="audio" preload="none"></audio>

  <script src="https://accounts.google.com/gsi/client" async defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jsmediatags/3.9.5/jsmediatags.min.js"></script>
  <script src="app.js"></script>
</body>
</html>
